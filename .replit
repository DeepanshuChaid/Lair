modules = ["go-1.21", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["goose"]

[userenv]

[userenv.shared]
NEON_DATABASE_URL = "postgresql://neondb_owner:npg_BesHc2uJ5hQR@ep-weathered-dew-a17qau8l-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd server && GOPATH=/tmp/gopath go run ./cmd/"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["/home/runner/workspace/server_bin"]
build = ["bash", "-c", "cd server && go build -o /home/runner/workspace/server_bin ./cmd/"]
